void ki_ekta_obostha()
{

        int n, m;
        cin >> n >> m;
        map < string, string > mp;
        for (int i = 0; i < m; i++){
            string a, b;
            cin >> a >> b;
            if (a.size() <= b.size()){
                mp[a] = a;
            }
            else{
                mp[a] = b;
            }
        }
        for (int i = 0; i < n; i++){
            string c;
            cin >> c;
            cout << mp[c] <<" ";
        }
        cout << endl;

      //Time Complexity: O((n+m)logm)
      //Time Complexity: O(m)
}
