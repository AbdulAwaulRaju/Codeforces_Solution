#include<bits/stdc++.h>
using namespace std;
int main(){
     int t;
     cin >> t;
     while(t--){
    long long n;
    cin >> n;
    vector<long long> v(n);
    for (auto& u : v)
        cin >> u;
    sort(v.rbegin(), v.rend());
    set<long long> s(v.begin(), v.end());
    if (s.size() < n)
        cout << "-1" << endl;
    else {
        for (auto& u : v)
            cout << u << " ";
        cout << endl;
    }
    }
    //Time Complexity : O(nlogn)
    //Space Complexity : O(n)
return 0;}
